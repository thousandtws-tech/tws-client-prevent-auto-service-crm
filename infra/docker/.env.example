# Copy to infra/docker/.env and adjust values
#
# Image / publish
IMAGE_PREFIX=your-dockerhub-user
IMAGE_TAG=dev
MODULE=prevent-monolith

# Optional runtime env (used by docker compose up)
SERVER_PORT=9090
DB_HOST=
DB_PORT=
DB_NAME=
DB_USERNAME=
DB_PASSWORD=
DB_SSL_MODE=
DB_CHANNEL_BINDING=
AUTH_JWT_SECRET=change-me
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:5173,http://127.0.0.1:5173
CLOUDINARY_ENABLED=false
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_BASE_FOLDER=prevent-auto-mecanica
CLOUDINARY_MAX_FILE_SIZE=5MB
SERVICE_ORDERS_PUBLIC_SIGNATURE_BASE_URL=http://localhost:5173/assinatura-os

